{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gethomepage.dev/schemas/kubernetes.schema.json",
  "title": "GetHomepage Kubernetes Configuration",
  "description": "Schema para o arquivo kubernetes.yaml do GetHomepage. Documentação: https://gethomepage.dev/configs/kubernetes/",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "description": "Modo de operação do Kubernetes.",
      "enum": ["disabled", "default", "cluster"],
      "default": "default"
    },
    "ingress": {
      "type": "boolean",
      "description": "Habilitar descoberta de Ingress.",
      "default": true
    },
    "traefik": {
      "type": "boolean",
      "description": "Habilitar descoberta de Traefik IngressRoute.",
      "default": false
    },
    "gateway": {
      "type": "boolean",
      "description": "Habilitar descoberta de Gateway API HttpRoute.",
      "default": false
    }
  },
  "additionalProperties": false
}
